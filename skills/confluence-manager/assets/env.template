# Confluence configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# Required: your self-hosted Confluence base URL
CONFLUENCE_BASE_URL=https://cwiki.yunify.com

# Required: personal access token from Confluence
# Generate at: <your-confluence-url>/plugins/personalaccesstokens/usertokens.action
CONFLUENCE_PAT=your-token-here

# Optional: auth mode — "auto" tries bearer first, then basic if username is set
# CONFLUENCE_AUTH_MODE=auto

# Optional: username for basic auth fallback
# CONFLUENCE_USERNAME=your-username
